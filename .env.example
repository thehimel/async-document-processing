PROJECT_NAME=core

# Local API server port
API_PORT=8000

# Local PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=core
POSTGRES_PORT=5432

# Set true for Neon and other cloud Postgres that require SSL
# POSTGRES_SSL_REQUIRE=false

# Optional: test DB name (default: {POSTGRES_DB}_test)
# POSTGRES_DB_TEST=core_test

# Google OAuth — create credentials at console.cloud.google.com
# Add authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret for signing session tokens — generate with: `openssl rand -hex 32`
JWT_SECRET_KEY=your-jwt-secret-here

# Session middleware secret (signs the OAuth state cookie) — generate with: `openssl rand -hex 32`
SESSION_SECRET_KEY=your-session-secret-here

# CORS: "*" allows all origins (dev); comma-separated list for production
# CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:3000,https://example.com,https://www.example.io

# Frontend base URL for OAuth callback. Required when API is proxied via Next.js rewrites.
# Must match Google's authorized redirect URIs (frontend domain).
# Dev: http://localhost:3000
# Prod: https://example.com or https://www.example.com
# FRONTEND_URL=http://localhost:3000

# Session cookie domain. Auto-derived from FRONTEND_URL when unset (e.g. .example.com).
# Set explicitly to override. Required for OAuth state to persist across redirect when proxied.
# SESSION_COOKIE_DOMAIN=.example.com
